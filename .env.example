# Stripe
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Contact form email (SMTP)
# For Gmail: use an App Password (myaccount.google.com/apppasswords)
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# For other providers: set values accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_sending_address@gmail.com
SMTP_PASS=your_app_password_here
CONTACT_TO_EMAIL=your_receiving_address@gmail.com
